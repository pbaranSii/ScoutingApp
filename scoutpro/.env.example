#
# Szablon zmiennych środowiskowych dla ScoutApp
# Skopiuj do .env.local i uzupełnij prawdziwymi wartościami.
# NIGDY nie commituj .env.local do repo.
#
# ─────────────────────────────────────────────────────────────
#  ŚRODOWISKO | Supabase Project REF    | Gdzie konfigurowane
# ─────────────────────────────────────────────────────────────
#  LOCAL DEV  | digrvtbfonatvytwpbbn    | .env.local (ten plik)
#  PREVIEW     | digrvtbfonatvytwpbbn    | Variable group "scoutapp-swadeploy-preview" (Azure DevOps)
#  PRODUCTION  | oilillvaatchsyvqbyxo   | Variable group "scoutapp-swadeploy-prod" (Azure DevOps)
#  VERCEL PROD | digrvtbfonatvytwpbbn   | Panel Vercel → Environment Variables
# ─────────────────────────────────────────────────────────────

#
# Zmienne frontendowe (wstrzykiwane przez Vite w czasie builda).
# Użyj wartości z projektu Supabase: Dashboard → Settings → API.
#
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_APP_URL=http://localhost:5173

#
# Zmienne backendowe – używane w skryptach i Supabase CLI.
# Dla lokalnego dev wskaż projekt PREVIEW (digrvtbfonatvytwpbbn).
# Wartości PROD są ustawiane w panelach hostingu, nie tutaj.
#
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password
